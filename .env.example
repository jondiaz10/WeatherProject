# Copy this file to ".env" and fill in your own values.
# The .env file is git-ignored and must never be committed.

# Required: your OpenWeatherMap API key.
# Get a free key at https://home.openweathermap.org/api_keys
OPENWEATHERMAP_API_KEY=your-api-key-here

# Optional: override the API endpoint (defaults to the v2.5 current-weather URL).
# OPENWEATHERMAP_BASE_URL=https://api.openweathermap.org/data/2.5/weather

# Optional: default unit system when --units is not passed (metric | imperial).
# WEATHER_DEFAULT_UNITS=metric

# Optional: per-request HTTP timeout in seconds.
# WEATHER_REQUEST_TIMEOUT=10
